  nodes:
  - content: "\u4F60\u597D\u5B88\u5FA1\u8005\uFF01\u4F60\u7EC8\u4E8E\u6765\u4E86\u3002\u8FD1\u65E5\u4E09\u5904\u5C01\u5370\u4E4B\u5730\u9B54\u7269\u8086\u8650\uFF0C\u82E5\u518D\u65E0\u4EBA\u904F\u5236\u6574\u4E2A\u5927\u9646\u90FD\u5C06\u4E07\u52AB\u4E0D\u590D\u3002"
    speaker: "\u957F\u8001"
    isChoice: 0
    choices: []
  - content: "\uFF08\u51DD\u91CD\uFF09\u552F\u6709\u4F60\u80FD\u642D\u5EFA\u5B88\u5FA1\u9632\u7EBF\uFF0C\u6DF1\u5165\u8FD9\u4E09\u5904\u9669\u5883\uFF0C\u6E05\u527F\u9B54\u7269\u3001\u91CD\u94F8\u5C01\u5370\u3002\u8FD9\u4E00\u8DEF\u51F6\u9669\u4E07\u5206\uFF0C\u4E00\u65E6\u5728\u4EFB\u4F55\u4E00\u5904\u5931\u5B88\uFF0C\u6211\u4EEC\u90FD\u5C06\u518D\u65E0\u7FFB\u76D8\u4E4B\u673A\uFF0C\u62DC\u6258\u4F60\u4E86\u3002"
    speaker: "\u957F\u8001"
    isChoice: 0
    choices: []
  - content: "\u8FD9\u4E2A\u8270\u5DE8\u7684\u4EFB\u52A1\u4F60\u80FD\u63A5\u53D7\u5417\uFF1F"
    speaker: "\u957F\u8001"
    isChoice: 1
    choices:
    - text: "\u63A5\u53D7"
      targetNodeIndex: 3
    - text: "\u62D2\u7EDD"
      targetNodeIndex: 4
  - content: "\u592A\u597D\u4E86\uFF01\u6211\u4EEC\u4F1A\u5728\u5C0F\u9547\u575A\u5B88\u540E\u65B9\uFF0C\u7B49\u5F85\u4F60\u51EF\u65CB\u7684\u6D88\u606F\uFF0C\u613F\u4F60\u4E00\u8DEF\u5E73\u5B89\uFF0C\u6210\u529F\u7A33\u56FA\u5C01\u5370\u3002"
    speaker: "\u957F\u8001"
    isChoice: 0
    choices: []
  - content: "\u597D\u5427\uFF0C\u5982\u679C\u4F60\u6539\u53D8\u4E86\u4E3B\u610F\u968F\u65F6\u6765\u627E\u6211\u3002"
    speaker: "\u957F\u8001"
